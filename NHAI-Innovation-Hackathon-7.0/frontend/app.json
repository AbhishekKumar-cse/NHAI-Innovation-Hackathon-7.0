{
  "expo": {
    "name": "NHAI SecureID",
    "slug": "DatalakeApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "datalakeapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.DatalakeApp",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "MetroHost": "192.168.1.4",
        "NSLocalNetworkUsageDescription": "NHAI SecureID connects to your Mac to load the app during development.",
        "NSBonjourServices": [
          "_http._tcp"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.anonymous.DatalakeApp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "NHAI SecureID needs camera access for face enrollment and authentication."
        }
      ],
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1877F2",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-image"
    ],
    "extra": {
      "faceApiUrl": "http://192.168.1.4:8000"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
